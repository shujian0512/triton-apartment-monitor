# Apartment Website Configuration
APARTMENT_URL=https://thetritonfostercity.com/lease-now
# CSS selector to check for availability (e.g., ".available-now", "#availability-status")
AVAILABILITY_SELECTOR=.floorplan-availability
# Text content that indicates availability (e.g., "Available", "Now Available")
# The script will check if this text is present in the element
AVAILABILITY_TEXT=Available

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_FROM=+1234567890
TWILIO_PHONE_TO=+1234567890

# Monitoring Configuration
CHECK_INTERVAL_MINUTES=30
# Rate limiting: delay between requests in milliseconds
REQUEST_DELAY_MS=2000

# Enhanced Tracking Configuration
# NEW: Separate tracking from notifications!
#
# TRACK_FLOOR_PLANS: Which floor plans to track and store data for
#   Use "*" to track ALL floor plans on the page
#   Or specify specific plans: "Plan 1B, Plan 2A"
#
# NOTIFY_FLOOR_PLANS: Which floor plans to send notifications for (subset of tracked)
#   Must be specific plan names (can't use "*")
#
# Examples:
#   Track ALL plans, notify only on Plan 1B and Plan 2A:
#     TRACK_FLOOR_PLANS=*
#     NOTIFY_FLOOR_PLANS=Plan 1B, Plan 2A
#
#   Track specific plans, notify on all tracked:
#     TRACK_FLOOR_PLANS=Plan 1B, Plan 2A, Plan 3C
#     NOTIFY_FLOOR_PLANS=Plan 1B, Plan 2A, Plan 3C
#
TRACK_FLOOR_PLANS=*
NOTIFY_FLOOR_PLANS=Plan 1B, Plan 2A

# History Configuration
# How many days of history to keep (default: 90)
HISTORY_RETENTION_DAYS=90

# Legacy Configuration (for backward compatibility)
# If TRACK_FLOOR_PLANS and NOTIFY_FLOOR_PLANS are not set, these will be used:
# FLOOR_PLAN_NAMES=Plan 1B, Plan 2A
# FLOOR_PLAN_NAME=Plan 1B
